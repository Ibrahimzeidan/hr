# Database Configuration
# Supabase PostgreSQL connection string (required)
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
# Note: Supabase requires SSL. The connection automatically uses sslmode=require.
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres

# Cloudinary Configuration (optional - for image storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Maximum upload file size in MB (1-25)
MAX_UPLOAD_MB=8

# AI Configuration (Google Gemini)
# Optional: If GEMINI_API_KEY is not set, the system uses deterministic local fallback
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# Supabase Configuration (optional - only needed if using Supabase features beyond PostgreSQL)
# The DATABASE_URL above is sufficient for PostgreSQL connectivity.
# These additional keys are only needed if integrating with Supabase client features.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=